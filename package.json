{
  "name": "editable",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "verify:docs": "node scripts/verify-docs-inventory.mjs",
    "verify:boundaries": "node scripts/verify-editor-boundaries.mjs",
    "verify:internal": "node scripts/verify-internal.mjs",
    "verify:internal:stress": "node scripts/verify-internal.mjs --repeat=10",
    "verify:internal:soak": "node scripts/verify-internal.mjs --repeat=30",
    "verify:p0-input": "pnpm exec vitest run src/editor/internal/model/p0InputConformanceMatrix.test.ts src/editor/internal/testing/editorInputOracleContract.test.ts && pnpm run verify:browser",
    "verify:browser": "playwright test",
    "format": "biome format --write",
    "check": "biome check"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.8",
    "@interactive-os/json-document": "^1.0.1",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-start": "^1.168.26",
    "lucide-react": "^0.545.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.1.18",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@playwright/test": "^1.61.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^28.1.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
